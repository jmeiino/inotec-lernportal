generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  LEARNER
  TRAINER
  ADMIN
  MULTIPLICATOR
  CHAMPION
}

enum CompetenceLevel {
  L1
  L2
  L3
  L4
  F1
  F2
  F3
}

enum TrackCategory {
  FACH
  FUEHRUNG
}

enum BusinessRole {
  VERTRIEB
  PRODUKTION
  VERWALTUNG
  IT
  HR
  FUEHRUNG
}

enum SubmissionStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REWORK
}

enum SurveyType {
  BASELINE
  PULSE
  SELF_ASSESSMENT
  ANNUAL
}

enum SurveyQuestionType {
  LIKERT_5
  OPEN_TEXT
  LEVEL_SELF
  MULTIPLE_CHOICE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum ModuleStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MaterialType {
  HANDOUT
  PRESENTATION
  CHEATSHEET
  OTHER
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  TRUE_FALSE
  MATCHING
}

enum ModuleFormat {
  ONLINE
  PRESENCE
  HYBRID
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  image        String?
  role         Role          @default(LEARNER)
  department   String?
  businessRole BusinessRole?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  enrollments      Enrollment[]
  progress         ModuleProgress[]
  attempts         QuizAttempt[]
  comments         Comment[]
  certificates     Certificate[]
  trainedSchedules Schedule[]       @relation("TrainerSchedules")

  submissions      WorkProductSubmission[] @relation("SubmissionAuthor")
  reviews          WorkProductSubmission[] @relation("SubmissionReviewer")

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Track {
  id              String          @id @default(uuid())
  name            String
  description     String?         @db.Text
  competenceLevel CompetenceLevel
  category        TrackCategory   @default(FACH)
  businessRole    BusinessRole?
  sortOrder       Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]
}

model Module {
  id            String       @id @default(uuid())
  trackId       String
  code          String       @unique
  title         String
  description   String?      @db.Text
  durationHours Int
  format        ModuleFormat @default(ONLINE)
  sortOrder     Int
  prerequisites Json         @default("[]")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  track       Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  progress    ModuleProgress[]
  quizzes     Quiz[]
  materials   Material[]
  comments    Comment[]
  schedules   Schedule[]
  submissions WorkProductSubmission[]
}

model Lesson {
  id        String   @id @default(uuid())
  moduleId  String
  title     String
  contentMd String   @db.Text
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  lessonProgress LessonProgress[]
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model Enrollment {
  id          String           @id @default(uuid())
  userId      String
  trackId     String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

model ModuleProgress {
  id          String       @id @default(uuid())
  userId      String
  moduleId    String
  status      ModuleStatus @default(NOT_STARTED)
  progressPct Int          @default(0)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Quiz {
  id           String   @id @default(uuid())
  moduleId     String
  passingScore Int      @default(70)
  timeLimitMin Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String       @id @default(uuid())
  quizId        String
  question      String       @db.Text
  options       Json
  correctAnswer String
  explanation   String?      @db.Text
  type          QuestionType @default(SINGLE_CHOICE)
  sortOrder     Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id      String   @id @default(uuid())
  userId  String
  quizId  String
  score   Int
  passed  Boolean
  answers Json
  takenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Material {
  id        String       @id @default(uuid())
  moduleId  String
  title     String
  filePath  String
  type      MaterialType @default(OTHER)
  fileSize  Int?
  sortOrder Int
  createdAt DateTime     @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  moduleId  String
  parentId  String?
  content   String   @db.Text
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
}

model Certificate {
  id         String   @id @default(uuid())
  userId     String
  trackId    String
  certNumber String   @unique
  pdfPath    String?
  issuedAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model Schedule {
  id              String   @id @default(uuid())
  moduleId        String
  location        String
  startTime       DateTime
  endTime         DateTime
  maxParticipants Int
  trainerId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  module  Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  trainer User   @relation("TrainerSchedules", fields: [trainerId], references: [id])

  registrations ScheduleRegistration[]
}

model Survey {
  id          String     @id @default(uuid())
  type        SurveyType
  title       String
  description String?    @db.Text
  active      Boolean    @default(true)
  salt        String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([type])
  @@index([active])
}

model SurveyQuestion {
  id              String             @id @default(uuid())
  surveyId        String
  prompt          String             @db.Text
  type            SurveyQuestionType
  options         Json               @default("[]")
  competenceLevel CompetenceLevel?
  sortOrder       Int

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@index([surveyId])
}

model SurveyResponse {
  id              String           @id @default(uuid())
  surveyId        String
  responseHash    String
  department      String?
  businessRole    BusinessRole?
  competenceLevel CompetenceLevel?
  submittedAt     DateTime         @default(now())

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@unique([surveyId, responseHash])
  @@index([surveyId])
  @@index([department])
  @@index([businessRole])
}

model SurveyAnswer {
  id         String @id @default(uuid())
  responseId String
  questionId String
  value      String @db.Text

  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([responseId])
  @@index([questionId])
}

model WorkProductSubmission {
  id            String           @id @default(uuid())
  userId        String
  moduleId      String
  title         String
  descriptionMd String           @db.Text
  externalUrl   String?
  status        SubmissionStatus @default(SUBMITTED)
  reviewerId    String?
  reviewNotes   String?          @db.Text
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?
  updatedAt     DateTime         @updatedAt

  user     User   @relation("SubmissionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  reviewer User?  @relation("SubmissionReviewer", fields: [reviewerId], references: [id])

  @@index([userId])
  @@index([moduleId])
  @@index([reviewerId])
  @@index([status])
}

model ScheduleRegistration {
  id           String   @id @default(uuid())
  scheduleId   String
  userId       String
  registeredAt DateTime @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, userId])
}
